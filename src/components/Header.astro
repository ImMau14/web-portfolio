---
import Logo from '@/components/Logo'
---

<header class="fixed top-0 left-0 z-50 h-24 w-full px-4 py-4 text-white sm:px-10">
  <div
    class="glass mx-auto flex h-full w-full max-w-5xl items-center justify-center rounded-full px-6 sm:justify-between sm:px-10"
  >
    <h2 class="font-geist text-lg font-bold tracking-wide">
      <a href="/" class="flex flex-row items-center gap-3">
        <Logo className="w-8 shrink-0" />
        <span>ImMau14</span>
      </a>
    </h2>
    <nav class="opacity-90" aria-label="Main navigation">
      <ul class="font-geist flex flex-row items-center gap-4 sm:gap-8">
        <li class="transition-all hover:scale-105"><a href="/">Home</a></li>
        <li class="transition-all hover:scale-105"><a href="/projects">Projects</a></li>
        <li class="transition-all hover:scale-105"><a href="/about">About Me</a></li>
      </ul>
    </nav>
  </div>
</header>
