---
// Hobbies and interests section with icons.
---

<div>
  <h2 class="text-ui-text text-3xl font-geist font-bold mb-2">Beyond the Code</h2>
  <p class="text-ui-text-muted text-sm font-geist mb-8">
    Things I enjoy when I am not writing code.
  </p>

  <div class="grid grid-cols-2 gap-4">
    <!-- Calisthenics -->
    <div class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui text-center
                transition-all duration-300 ease-out hover:-translate-y-1 hover:border-ui-primary group">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-ui-base border border-ui-border/50 mb-3
                  group-hover:bg-ui-primary/10 group-hover:scale-110 transition-all duration-300">
        <svg class="w-6 h-6 text-ui-text-muted group-hover:text-ui-primary transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
      <p class="text-sm font-geist font-medium text-ui-text group-hover:text-ui-primary transition-colors duration-300">Calisthenics</p>
    </div>

    <!-- Drawing -->
    <div class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui text-center
                transition-all duration-300 ease-out hover:-translate-y-1 hover:border-ui-primary group">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-ui-base border border-ui-border/50 mb-3
                  group-hover:bg-ui-primary/10 group-hover:scale-110 transition-all duration-300">
        <svg class="w-6 h-6 text-ui-text-muted group-hover:text-ui-primary transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
      </div>
      <p class="text-sm font-geist font-medium text-ui-text group-hover:text-ui-primary transition-colors duration-300">Drawing</p>
    </div>

    <!-- Music -->
    <div class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui text-center
                transition-all duration-300 ease-out hover:-translate-y-1 hover:border-ui-primary group">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-ui-base border border-ui-border/50 mb-3
                  group-hover:bg-ui-primary/10 group-hover:scale-110 transition-all duration-300">
        <svg class="w-6 h-6 text-ui-text-muted group-hover:text-ui-primary transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
        </svg>
      </div>
      <p class="text-sm font-geist font-medium text-ui-text group-hover:text-ui-primary transition-colors duration-300">Music</p>
    </div>

    <!-- Friends -->
    <div class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui text-center
                transition-all duration-300 ease-out hover:-translate-y-1 hover:border-ui-primary group">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-ui-base border border-ui-border/50 mb-3
                  group-hover:bg-ui-primary/10 group-hover:scale-110 transition-all duration-300">
        <svg class="w-6 h-6 text-ui-text-muted group-hover:text-ui-primary transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
      <p class="text-sm font-geist font-medium text-ui-text group-hover:text-ui-primary transition-colors duration-300">Friends</p>
    </div>
  </div>
</div>
