---
// Stack and skills section with categorized tech icons.

import { Image } from 'astro:assets'

const categories = [
  {
    title: 'Frontend',
    icons: ['html', 'css', 'js', 'ts', 'astro', 'react', 'tailwind'],
  },
  {
    title: 'Backend',
    icons: ['py', 'flask', 'actix', 'rust', 'fastapi'],
  },
  {
    title: 'Databases',
    icons: ['supabase', 'sqlite'],
  },
  {
    title: 'Editors',
    icons: ['vim', 'neovim'],
  },
  {
    title: 'Design',
    icons: ['ps', 'au'],
  },
  {
    title: 'DevOps & Others',
    icons: ['git', 'vercel', 'selenium', 'linux', 'windows', 'md'],
  },
]

const coreStrengths = ['TypeScript', 'React']
const preferredStack = [
  { label: 'Database', value: 'PostgreSQL' },
  { label: 'Backend', value: 'Rust' },
  { label: 'Frontend', value: 'TypeScript + React' },
]
---

<div>
  <h2 class="text-ui-text text-3xl font-geist font-bold mb-2">Stack & Skills</h2>
  <p class="text-ui-text-muted text-sm font-geist mb-8">
    Technologies I use daily to build full-stack projects, from the user interface to the database and deployment.
  </p>

  <!-- Core strengths -->
  <div class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui mb-6 transition-all duration-300 hover:-translate-y-1 hover:border-ui-primary">
    <h3 class="text-lg font-geist font-semibold text-ui-text mb-3">Core Strengths</h3>
    <hr class="border-ui-border/30 mb-4" />
    <div class="flex flex-wrap gap-3">
      {coreStrengths.map((skill) => (
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-ui-primary/10 text-ui-primary border border-ui-primary/20 text-sm font-medium font-geist transition-all duration-200 hover:bg-ui-primary/20 hover:scale-105">
          {skill}
        </span>
      ))}
    </div>
  </div>

  <!-- Preferred stack — clean vertical list -->
  <div class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui mb-6 transition-all duration-300 hover:-translate-y-1 hover:border-ui-primary">
    <h3 class="text-lg font-geist font-semibold text-ui-text mb-3">Preferred Stack</h3>
    <hr class="border-ui-border/30 mb-4" />
    <div class="space-y-3">
      {preferredStack.map((item) => (
        <div class="flex items-center gap-4 py-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-ui-text-muted w-24 shrink-0">{item.label}</span>
          <span class="text-sm font-medium text-ui-primary">{item.value}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Full grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {categories.map((cat) => (
      <div
        class="bg-ui-front border border-ui-border rounded-xl p-5 shadow-3ui
               transition-all duration-300 ease-out
               hover:-translate-y-1 hover:border-ui-primary"
      >
        <h3 class="text-lg font-geist font-semibold text-ui-text mb-3 flex items-center gap-2">
          {cat.title}
        </h3>
        <hr class="border-ui-border/30 mb-4" />
        <div class="flex flex-wrap gap-2">
          {cat.icons.map((icon) => (
            <Image
              src={`https://skillicons.dev/icons?i=${icon}&theme=dark`}
              alt={icon}
              title={icon}
              width={36}
              height={36}
              class="w-9 h-9 rounded-md
                     transition-all duration-300 ease-out
                     hover:scale-125 hover:rotate-6 hover:brightness-125
                     hover:drop-shadow-[0_0_6px_rgba(168,85,247,0.5)]"
            />
          ))}
        </div>
      </div>
    ))}
  </div>
</div>
