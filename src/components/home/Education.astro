---
// Education section with timeline and sticky sidebar.

export interface EducationEntry {
  degree: string
  institution: string
  period: string
  description: string
}

export interface Props {
  education: EducationEntry[]
}

const { education } = Astro.props
---

<section class="my-30">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <!-- Left column: Heading & summary (sticky on desktop) -->
    <div class="md:col-span-4">
      <div class="md:sticky md:top-28">
        <h2 class="text-ui-text text-3xl font-geist font-bold mb-4">Education</h2>
        <p class="text-ui-text-muted text-sm leading-relaxed mb-8">
          Timeline of my professional education and academic journey. I focus on bridging the gap between theoretical systems engineering and practical implementation.
        </p>
        <!-- Academic Profile indicator (visible only on desktop) -->
        <div class="hidden md:flex items-center gap-2 text-ui-primary mb-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
          </svg>
          <span class="text-xs font-semibold uppercase tracking-wider">Academic Profile</span>
        </div>
        <div class="hidden md:block h-1 w-20 bg-ui-primary/20 rounded-full"></div>
      </div>
    </div>

    <!-- Right column: Timeline -->
    <div class="md:col-span-8">
      <div class="space-y-10">
        {education.map((entry, idx) => {
          const isLast = idx === education.length - 1;
          const isCurrent = entry.period.includes('Currently') || entry.period.includes('Present');

          return (
            <div class={`relative pl-10 ${!isLast ? 'timeline-connector-left' : ''}`}>
              {/* Dot */}
              <div class="absolute left-0 top-8 -translate-x-1/2 w-3 h-3 rounded-full bg-ui-primary ring-4 ring-ui-back shadow-[0_0_12px_var(--ui-glow-primary)] z-10 transition-all duration-300 hover:scale-125"></div>

              {/* Card */}
              <div class="bg-ui-front border border-ui-border rounded-xl p-6 shadow-3ui transition-all duration-300 ease-out hover:-translate-y-1 hover:border-ui-primary group">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
                  <span class={`text-[10px] font-semibold uppercase tracking-widest px-3 py-1 rounded-full border transition-colors duration-200 ${
                    isCurrent
                      ? 'bg-ui-primary/10 text-ui-primary border-ui-primary/20 hover:bg-ui-primary/20'
                      : 'bg-ui-back text-ui-text-muted border-ui-border hover:border-ui-primary/30 hover:text-ui-text'
                  }`}>
                    {entry.period}
                  </span>
                </div>
                <h3 class="text-lg font-bold text-ui-text mb-1 group-hover:text-ui-primary transition-colors">{entry.degree}</h3>
                <p class="text-xs font-semibold uppercase tracking-tight text-ui-text-muted mb-3">{entry.institution}</p>
                <p class="text-sm text-ui-text-muted leading-relaxed">{entry.description}</p>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Concluding quote -->
      <div class="mt-12 pt-8 border-t border-ui-border/30">
        <p class="text-sm text-ui-text-muted font-geist italic leading-relaxed text-left">
          "I have learned a great deal about programming thanks to numerous content creators such as <span class="text-ui-primary font-medium">Midudev</span>, <span class="text-ui-primary font-medium">FreeCodeCamp</span>, among others, and also to university professors who taught me. Moreover, I have used <span class="text-ui-primary font-medium">artificial intelligence</span> to study related topics more easily."
        </p>
      </div>
    </div>
  </div>
</section>
