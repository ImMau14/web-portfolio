---
// Base HTML layout with meta tags, favicon, theme initialization script, and CSP nonce support.

import '@/styles/global.css'
import SeoHead from '@/components/SeoHead.astro'

export interface Props {
  title: string
  seo?: {
    title?: string
    description?: string
    image?: string
    url?: string
  }
}

const { title, seo } = Astro.props
const finalTitle = seo?.title ?? title

const nonce = Astro.locals?.cspNonce ?? ''
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SeoHead
      title={finalTitle}
      {...(seo?.description ? { description: seo.description } : {})}
      {...(seo?.image ? { image: seo.image } : {})}
      {...(seo?.url ? { url: seo.url } : {})}
      titleSuffix=" - ImMau14"
      siteUrl="https://immau14.vercel.app"
    />
    
    <!-- Apply dark theme immediately to avoid flash -->
    <script is:inline nonce={nonce}>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="overflow-x-hidden bg-ui-back font-geist">
    <main id="main" class="scroll-mt-24">
      <slot />
    </main>
  </body>
</html>
