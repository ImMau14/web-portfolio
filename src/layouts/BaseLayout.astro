---
// Base HTML layout with meta tags, favicon, theme initialization script, and CSP nonce support.

import '@/styles/global.css'

export interface Props {
  title: string
  description?: string
}

const nonce = Astro.locals?.cspNonce ?? ''
---

<!doctype html>
<html lang="en">
  <head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <!-- Apply dark theme immediately to avoid flash -->
    <script is:inline nonce={nonce}>
      (function () {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-ui-back font-geist">
    <main id="main">
      <slot />
    </main>
  </body>
</html>
