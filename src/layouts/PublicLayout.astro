---
// Layout for public-facing pages, includes AmbientGlow and Footer.

import AmbientGlow from '@/components/AmbientGlow'
import Footer from '@/components/Footer.astro'
import Header from '@/components/Header.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'

export interface Props {
  title: string
  seo?:
    | {
        title?: string | undefined
        description?: string | undefined
        image?: string | undefined
        url?: string | undefined
      }
    | undefined
    | null
}
---

<BaseLayout title={Astro.props.title} seo={Astro.props.seo ?? undefined}>
  <div class="relative flex min-h-screen flex-col overflow-hidden">
    <AmbientGlow />
    <Header />
    <div class="mx-auto w-full max-w-5xl flex-1 px-4 pt-25 sm:pt-20 md:pt-15 sm:px-6 lg:px-8">
      <slot />
    </div>
    <Footer />
  </div>
</BaseLayout>
