---
// Home page placeholder with a welcome message.

import PublicLayout from '@/layouts/PublicLayout.astro'
---

<PublicLayout title="Home">
  <section class="flex min-h-[calc(100vh-6rem)] flex-col items-center justify-center text-center">
    <h1 class="font-geist text-4xl font-bold text-ui-text sm:text-5xl lg:text-6xl">
      Welcome
    </h1>
    <p class="mt-4 max-w-lg text-balance text-lg text-ui-text-muted sm:text-xl">
      Explore my work.
    </p>
  </section>
</PublicLayout>
